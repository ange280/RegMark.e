<!DOCTYPE html><html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LogoMart CI</title>
<style>
body{font-family:Arial, sans-serif;margin:0;background:#0f172a;color:white}
header{text-align:center;padding:40px 20px;background:linear-gradient(135deg,#2563eb,#7c3aed)}
header h1{margin:0;font-size:32px}
.container{max-width:1100px;margin:auto;padding:30px 20px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px}
.card{background:#1e293b;border-radius:14px;padding:15px;text-align:center;box-shadow:0 10px 20px rgba(0,0,0,0.4);transition:transform .2s}
.card:hover{transform:translateY(-5px)}
.card img{width:100%;border-radius:10px;background:white}
.price{margin:10px 0;font-weight:bold;font-size:18px;color:#22c55e}
button{background:#25D366;border:none;padding:10px 16px;border-radius:8px;cursor:pointer;font-weight:bold}
button:hover{opacity:0.9}
footer{text-align:center;padding:25px;opacity:0.7}
</style>
</head><body><header>
<h1>LogoMart CI</h1>
<p>Logos professionnels pour startups et entreprises</p>
</header><div class="container">
<div class="grid"><!-- LOGO 1 --><div class="card">
<img src="https://via.placeholder.com/400x300?text=NovaTech" alt="NovaTech">
<h3>NovaTech</h3>
<div class="price">20000 FCFA</div>
<button onclick="buyLogo('NovaTech','20000')">Acheter</button>
</div><!-- LOGO 2 --><div class="card">
<img src="https://via.placeholder.com/400x300?text=UrbanFit" alt="UrbanFit">
<h3>UrbanFit</h3>
<div class="price">20000 FCFA</div>
<button onclick="buyLogo('UrbanFit','20000')">Acheter</button>
</div><!-- LOGO 3 --><div class="card">
<img src="https://via.placeholder.com/400x300?text=GreenBite" alt="GreenBite">
<h3>GreenBite</h3>
<div class="price">20000 FCFA</div>
<button onclick="buyLogo('GreenBite','20000')">Acheter</button>
</div></div>
</div><footer>
Paiement via Wave ou MTN MoMo • Contact WhatsApp
</footer><script>
const phone = "2250584161702";

function buyLogo(name,price){
const msg=`Bonjour, je souhaite acheter le logo ${name} à ${price} FCFA sur votre site LogoMart.`;
const url=`https://wa.me/${phone}?text=${encodeURIComponent(msg)}`;
window.open(url,"_blank");
}
</script></body>
</html>
